# Safety gates
RG_KILL_SWITCH=false
# Live trading additionally requires the per-run `--confirm-live` CLI flag.
RG_LIVE_TRADING_ENABLED=false

# Local fixture/data paths
RG_MARKETS_PATH=examples/markets/kalshi_markets.json

# Kalshi credentials for a future live adapter.
# Keep real secrets in .env only; never commit them.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_BASE_URL=https://external-api.demo.kalshi.co/trade-api/v2
KALSHI_MARKET_DATA_BASE_URL=https://external-api.kalshi.com/trade-api/v2

# Optional read-only sports odds source.
THE_ODDS_API_KEY=

THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
